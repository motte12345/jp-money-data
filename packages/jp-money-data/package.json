{
  "name": "jp-money-data",
  "version": "0.1.0",
  "description": "日本の生活マネー制度データ（自賠責・軽自動車税・標準報酬月額・雇用保険など）を出典・改定履歴つきの JSON + TypeScript 型で提供する OSS。Japanese money/social-insurance/tax parameters as machine-readable data with sources and revision history.",
  "keywords": ["japan", "japanese", "tax", "social-insurance", "dataset", "open-data", "json"],
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./datasets/*": {
      "types": "./dist/generated/*.d.ts",
      "import": "./dist/generated/*.js",
      "require": "./dist/generated/*.cjs"
    }
  },
  "files": ["dist", "data", "LICENSE", "README.md"],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm --prefix ../.. run build"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.7.3"
  }
}
